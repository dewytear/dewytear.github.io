    <thead><tr><th>시점</th><th>기법</th><th>찾으려는 unknown</th></tr></thead>
    <tbody>
        <tr><td>시작 전</td><td>Blind Spot Check</td><td>도메인 자체를 몰라 놓친 것</td></tr>
