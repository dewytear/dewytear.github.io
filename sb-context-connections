    <rect class="d-box" x="596" y="60" width="70" height="56" rx="10"/>
    <text class="d-label sm" x="631" y="92" text-anchor="middle">답변</text>

    <line class="d-edge accent" x1="164" y1="88" x2="202" y2="88"/><polygon class="d-arrow accent" points="202,83 210,88 202,93"/>
    <text class="d-sub" x="183" y="78" text-anchor="middle">없으면</text>
    <line class="d-edge" x1="364" y1="88" x2="402" y2="88"/><polygon class="d-arrow" points="402,83 410,88 402,93"/>
